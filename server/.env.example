# USE_MEMORY_DB=1 runs MongoDB in RAM — works without Docker or Atlas (npm run dev).
# Set USE_MEMORY_DB=0 and point MONGO_URI to Atlas or local mongod for persistent DB.
USE_MEMORY_DB=1

# Atlas example when USE_MEMORY_DB=0:
# MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/mern-crm?retryWrites=true&w=majority
# Local Docker when USE_MEMORY_DB=0:
# MONGO_URI=mongodb://127.0.0.1:27017/mern-crm
MONGO_URI=mongodb://127.0.0.1:27017/mern-crm
JWT_SECRET=
PORT=5000
